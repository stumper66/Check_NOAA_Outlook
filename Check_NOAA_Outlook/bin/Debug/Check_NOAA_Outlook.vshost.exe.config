<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
    <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
    </sectionGroup>
  </configSections>
  <log4net>
    <root>
      <level value="ALL"/> <!-- change to ALL to include debug, otherwise use INFO -->
      <appender-ref ref="LogFileAppender"/>
    </root>
    <appender name="LogFileAppender" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="Check_NOAA_Outlook.Log"/>
      <param name="AppendToFile" value="true"/>
      <rollingStyle value="Size"/>
      <maxSizeRollBackups value="4"/>
      <maximumFileSize value="5MB"/>
      <staticLogFileName value="true"/>
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%date [%thread] %-5level %logger - %message%newline"/>
      </layout>
    </appender>
  </log4net>
<appSettings>
  <add key="Email_Host" value="192.168.0.85" />
  <add key="Email_From" value="stephen12@twc.com" />
  <add key="Email_ReplyTo" value="buffalo246@outlook.com" />
  <add key="Email_Test_Address" value="buffalo246@outlook.com (Stephen)"/>
  <add key="Email_HighPri_Min_Criteria" value="2" />
  <add key="EMail_IsEnabled" value="true" />
  <add key="Download_Timeout_Seconds" value="30" />
  <add key="Download_Max_Retries" value="3" />
  <add key="NOAA_Main_URL" value="http://www.spc.noaa.gov/products/outlook/" />
</appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.1" />
  </startup>
</configuration>